---
export interface Props {
  currentTopic?: string;
  currentPillar?: string;
}

const { currentTopic = "Spanish Rice Dishes", currentPillar = "" } = Astro.props;

const pillars = [
  { slug: "", label: "Overview" },
  { slug: "history", label: "History & Evolution" },
  { slug: "technical-deep-dive", label: "Technical Deep-Dive" },
  { slug: "ontology", label: "Ontology" },
  { slug: "trends", label: "Trends" },
  { slug: "tools", label: "Tools" },
  { slug: "challenges", label: "Challenges" }
];

const topicSlug = "spanish-rice-dishes";
---

<nav class="breadcrumb-nav" aria-label="Breadcrumb">
  <div class="breadcrumb">
    <a href="/">Home</a>
    <span class="separator">/</span>
    <a href={`/${topicSlug}/`}>{currentTopic}</a>
    {currentPillar && (
      <>
        <span class="separator">/</span>
        <span class="current">{currentPillar}</span>
      </>
    )}
  </div>
</nav>

<nav class="pillar-nav" aria-label="Pillar pages">
  <h3>In this topic:</h3>
  <ul>
    {pillars.map(pillar => {
      const href = pillar.slug ? `/${topicSlug}/${pillar.slug}/` : `/${topicSlug}/`;
      const isActive = currentPillar === pillar.label || (!currentPillar && !pillar.slug);
      return (
        <li>
          <a href={href} class={isActive ? "active" : ""}>
            {pillar.label}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<style>
  .breadcrumb-nav {
    margin-bottom: 2rem;
  }

  .breadcrumb {
    font-family: 'Lato', -apple-system, sans-serif;
    font-size: 0.85rem;
    color: #8a8a8a;
  }

  .breadcrumb a {
    color: #5a5a5a;
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #2b2b2b;
  }

  .separator {
    margin: 0 0.5rem;
    color: #c4c4c4;
  }

  .current {
    color: #2b2b2b;
    font-weight: 600;
  }

  .pillar-nav {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: #f8f7f5;
    border: 1px solid #e8e6e0;
  }

  .pillar-nav h3 {
    font-family: 'Lato', -apple-system, sans-serif;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #2b2b2b;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .pillar-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pillar-nav li {
    margin-bottom: 0.5rem;
  }

  .pillar-nav a {
    display: block;
    padding: 0.5rem 0;
    color: #5a5a5a;
    text-decoration: none;
    font-size: 0.95rem;
    border-left: 3px solid transparent;
    padding-left: 0.75rem;
    margin-left: -0.75rem;
    transition: all 0.2s;
  }

  .pillar-nav a:hover {
    color: #2b2b2b;
    border-left-color: #c4c4c4;
  }

  .pillar-nav a.active {
    color: #2b2b2b;
    font-weight: 600;
    border-left-color: #2b2b2b;
  }
</style>
