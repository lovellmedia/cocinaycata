---
export interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="content-section">
  {title && <h2>{title}</h2>}
  <slot />
</div>

<style>
  .content-section {
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 1.5rem;
  }

  .content-section :global(h3) {
    font-size: 1.35rem;
    font-weight: 600;
    color: #2b2b2b;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .content-section :global(h4) {
    font-size: 1.15rem;
    font-weight: 600;
    color: #3a3a3a;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .content-section :global(p) {
    font-size: 1.1rem;
    color: #3a3a3a;
    margin-bottom: 1.5rem;
    line-height: 1.8;
    text-align: justify;
  }

  .content-section :global(ul),
  .content-section :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .content-section :global(li) {
    font-size: 1.1rem;
    color: #3a3a3a;
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }

  .content-section :global(a) {
    color: #2b2b2b;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .content-section :global(a:hover) {
    color: #000000;
  }

  .content-section :global(blockquote) {
    background: #f8f7f5;
    padding: 1.5rem;
    border-left: 3px solid #2b2b2b;
    margin: 2rem 0;
    font-style: italic;
    color: #4a4a4a;
  }

  .content-section :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    background: #ffffff;
  }

  .content-section :global(th) {
    font-family: 'Lato', -apple-system, sans-serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 1rem;
    text-align: left;
    border-bottom: 2px solid #2b2b2b;
    background: #f8f7f5;
    font-weight: 700;
  }

  .content-section :global(td) {
    padding: 1rem;
    border-bottom: 1px solid #e8e6e0;
    font-size: 1rem;
    color: #3a3a3a;
  }

  .content-section :global(tr:last-child td) {
    border-bottom: 2px solid #2b2b2b;
  }

  @media (max-width: 968px) {
    .content-section :global(table) {
      font-size: 0.9rem;
    }

    .content-section :global(th),
    .content-section :global(td) {
      padding: 0.75rem 0.5rem;
    }
  }
</style>
