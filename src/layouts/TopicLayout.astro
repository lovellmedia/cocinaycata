---
import BaseLayout from './BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import ContentSection from '../components/ContentSection.astro';
import Sidebar from '../components/Sidebar.astro';

export interface Props {
  title: string;
  description?: string;
  topic?: string;
  pillar?: string;
  relatedTopics?: Array<{ title: string; url: string }>;
  keyPoints?: string[];
}

const { 
  title, 
  description,
  topic = "Spanish Rice Dishes",
  pillar = "",
  relatedTopics = [],
  keyPoints = []
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="page-container">
    <div class="content-wrapper">
      <article class="main-content">
        <Navigation currentTopic={topic} currentPillar={pillar} />
        <h1>{pillar || title}</h1>
        <ContentSection>
          <slot />
        </ContentSection>
      </article>
      <aside class="sidebar-container">
        <Sidebar relatedTopics={relatedTopics} keyPoints={keyPoints} />
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem;
  }

  .content-wrapper {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
  }

  .main-content {
    min-width: 0;
  }

  .main-content h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a1a1a;
    margin-bottom: 1.5rem;
    line-height: 1.3;
  }

  .sidebar-container {
    min-width: 0;
  }

  @media (max-width: 968px) {
    .page-container {
      padding: 2rem 1.5rem;
    }

    .content-wrapper {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .main-content h1 {
      font-size: 2rem;
    }
  }
</style>
